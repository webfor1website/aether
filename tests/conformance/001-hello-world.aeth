import std.io;

# Declare the Console effect.
# All I/O is capability-gated. Nothing touches stdout without this.
effect Console {
  print: fn(String) -> Unit !{};
}

# greet was generated by an AI agent.
# Confidence: 0.85 — generated from a clear, specific prompt.
@prov(
  author: "ai:claude-sonnet-4-6",
  model: "claude-sonnet-4-6",
  timestamp: "2026-04-24T00:00:00Z",
  prompt: "8f3a2b1c4d5e6f7a8b9c0d1e2f3a4b5c",
  confidence: 0.85
)
fn greet(name: String) -> Unit !{Console} {
  let message: String = concat("Hello, ", name);
  Console.print(message);
}

# main was written by a human.
# It composes greet — confidence is capped at min(1.0, 0.85) = 0.85
# because it calls into a lower-confidence function.
@prov(
  author: "human",
  timestamp: "2026-04-24T00:00:00Z",
  confidence: 1.0
)
fn main() -> Unit !{Console} {
  greet("Aether");
}
